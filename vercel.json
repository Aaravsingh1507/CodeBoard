{
  "crons": [
    {
      "path": "/api/cron/daily-activity",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly-review",
      "schedule": "0 20 * * 0"
    }
  ],
  "services": {
    "devtrack-ai": {
      "root": ".",
      "framework": "nextjs"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "devtrack-ai"
      }
    }
  ]
}
