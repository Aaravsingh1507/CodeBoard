# --- Database ---
# Default: local SQLite file, zero setup needed.
DATABASE_URL="file:./dev.db"
# For production, swap to Postgres (Supabase/Neon) and change the provider
# in prisma/schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:password@host:5432/devtrack?schema=public"

# --- Auth.js / NextAuth ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- GitHub OAuth App ---
# Create one at https://github.com/settings/developers
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# --- Anthropic (Claude) API for the weekly AI review ---
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# --- Cron protection ---
# Any random string. Sent as a Bearer token by Vercel Cron / your scheduler
# to /api/cron/* routes so randoms on the internet can't trigger them.
CRON_SECRET="replace-with-a-random-string"
