generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(cuid())
  githubId              String?         @unique
  githubUsername        String?
  leetcodeUsername      String?
  name                  String?
  email                 String?         @unique
  emailVerified         DateTime?
  image                 String?
  avatarUrl             String?
  targetRole            String?
  targetCompanies       String?
  jobSearchStatus       String?         @default("not_looking")
  githubAccessToken     String?
  onboarded             Boolean         @default(false)
  theme                 String          @default("dark")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  githubStatsCache      String?
  githubStatsSyncedAt   DateTime?
  leetcodeStatsCache    String?
  leetcodeStatsSyncedAt DateTime?
  accounts              Account[]
  activityLogs          ActivityLog[]
  applications          Application[]
  goals                 Goal[]
  resumeVersions        ResumeVersion[]
  sessions              Session[]
  weeklyReviews         WeeklyReview[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ActivityLog {
  id                  String   @id @default(cuid())
  userId              String
  date                DateTime
  githubContributions Int      @default(0)
  leetcodeSubmissions Int      @default(0)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model ResumeVersion {
  id         String   @id @default(cuid())
  userId     String
  fileUrl    String
  fileName   String
  label      String
  notes      String?
  isActive   Boolean  @default(false)
  uploadedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id        String    @id @default(cuid())
  userId    String
  company   String
  role      String
  link      String?
  status    String    @default("wishlist")
  appliedAt DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyReview {
  id           String   @id @default(cuid())
  userId       String
  weekStart    DateTime
  weekEnd      DateTime
  summaryText  String
  observations String
  suggestions  String
  generatedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  type      String
  label     String
  target    Int
  current   Int      @default(0)
  deadline  DateTime
  status    String   @default("in_progress")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
